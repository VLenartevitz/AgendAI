    </section>
</main>

@code {
    private string accountType = "User";
    private string fullName = string.Empty;
    private string businessName = string.Empty;
    private string whatsAppNumber = string.Empty;
    private string email = string.Empty;
    private string password = string.Empty;
    private string apiMessage = "Carregando mensagem da API...";
    private string statusMessage = string.Empty;
    private bool isSubmitting;

    private string EnterpriseTitle => "Dashboard da Enterprise";

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("Api");
            apiMessage = await client.GetStringAsync("/api/info/message");
        }
        catch
        {
            apiMessage = "Conexao com a API indisponivel no momento.";
        }
    }

    private async Task GoToDashboardAsync()
    {
        if (accountType == "Enterprise" && string.IsNullOrWhiteSpace(businessName))
        {
            statusMessage = "Informe o nome do negocio para continuar.";
            return;
        }

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            statusMessage = "Informe e-mail e senha para continuar.";
            return;
        }

        isSubmitting = true;
        statusMessage = string.Empty;

        try
        {
            var client = HttpClientFactory.CreateClient("Api");

            if (accountType == "Enterprise")
            {
                var request = new LoginRequest(email.Trim(), password);
                var response = await client.PostAsJsonAsync("/api/enterprises/login", request);
                if (!response.IsSuccessStatusCode)
                {
                    statusMessage = response.StatusCode == System.Net.HttpStatusCode.Unauthorized
                        ? "Senha incorreta para este e-mail."
                        : "Nao foi possivel iniciar a sessao agora.";
                    return;
                }

                var enterprise = await response.Content.ReadFromJsonAsync<EnterpriseSummaryApiDto>();
                if (enterprise is null)
                {
                    statusMessage = "Resposta inesperada da API.";
                    return;
                }

                SessionState.SetPrincipal(new SessionPrincipalDto(
                    enterprise.Id,
                    "Enterprise",
                    enterprise.Name,
                    enterprise.Email));

                Navigation.NavigateTo($"/e/{enterprise.Slug}");
                return;
            }

            var userRequest = new LoginRequest(email.Trim(), password);
            var userResponse = await client.PostAsJsonAsync("/api/users/login", userRequest);
            if (!userResponse.IsSuccessStatusCode)
            {
                statusMessage = userResponse.StatusCode == System.Net.HttpStatusCode.Unauthorized
                    ? "Senha incorreta para este e-mail."
                    : "Nao foi possivel iniciar a sessao agora.";
                return;
            }

            var user = await userResponse.Content.ReadFromJsonAsync<UserSummaryApiDto>();
            if (user is null)
            {
                statusMessage = "Resposta inesperada da API.";
                return;
            }

            SessionState.SetPrincipal(new SessionPrincipalDto(
                user.Id,
                "User",
                user.FullName,
                user.Email));

            Navigation.NavigateTo("/e/demo");
        }
        catch
        {
            statusMessage = "Erro ao conectar com a API.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
