@page "/login"
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject UserSessionState SessionState

<PageTitle>Login</PageTitle>

<main class="login-shell">
    <section class="login-brand-panel">
        <div class="login-brand-copy">
            <span class="eyebrow">Plataforma AgendAI</span>
            <h1>@HeroTitle</h1>

            <p>
                @HeroDescription
            </p>
        </div>

        <div class="logo-showcase">
            <img class="logo-showcase-image" src="/images/logoAgendAIWhite.jpeg" alt="Logo AgendAI" />
        </div>
    </section>

    <section class="login-page">
        <img class="login-logo" src="/images/logoAgendAI.png" alt="AgendAI" />
        <h2>Acessar dashboard</h2>

        <form class="login-form" @onsubmit="GoToDashboardAsync" @onsubmit:preventDefault>

  

            <input @bind="email" type="email" placeholder="E-mail" />

            <input @bind="password" type="password" placeholder="Senha" />

            <div class="account-type-group" aria-label="Tipo de conta">
                <InputRadioGroup @bind-Value="accountType">

                    <label class="account-type-option @(accountType == "User" ? "active" : "")">
                        <InputRadio Value="@("User")" />

                        <span class="account-type-dot"></span>

                        <span>
                            <strong>Usuario</strong>
                            <small>
                                Agenda pessoal e marcar horario em empresas
                            </small>
                        </span>
                    </label>

                    <label class="account-type-option @(accountType == "Enterprise" ? "active" : "")">
                        <InputRadio Value="@("Enterprise")" />

                        <span class="account-type-dot"></span>

                        <span>
                            <strong>Empresa</strong>
                            <small>
                                Agenda da Equipe e dos Clientes
                            </small>
                        </span>
                    </label>

                </InputRadioGroup>
            </div>

            <button type="submit" disabled="@isSubmitting">
                @(isSubmitting ? "Entrando..." : "Fazer login")
            </button>

            <button type="button" @onclick='() => Navigation.NavigateTo("/register")' disabled="@isSubmitting">

                Não possui conta? Registre-se

            </button>

        </form>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <p class="api-message">@statusMessage</p>
        }
    </section>
</main>

@code {
    private string accountType = "User";
    private string email = string.Empty;
    private string password = string.Empty;
    private string statusMessage = string.Empty;
    private bool isSubmitting;
    private string HeroTitle =>
        accountType == "Enterprise"
            ? "Dashboard da Empresa"
            : "Agenda pessoal";

    private string HeroDescription =>
        accountType == "Enterprise"
            ? "Gerencie reunioes, clientes e atendimentos da sua equipe em tempo real."
            : "Organize seus compromissos, acompanhe horarios e agende reunioes com empresas.";

    
    private async Task GoToDashboardAsync()
    {

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            statusMessage = "Informe e-mail e senha para continuar.";
            return;
        }

        isSubmitting = true;
        statusMessage = string.Empty;

        try
        {
            var client = HttpClientFactory.CreateClient("Api");

            if (accountType == "Enterprise")
            {
                var request = new LoginRequest(email.Trim(), password);
                var response = await client.PostAsJsonAsync("/api/enterprises/login", request);
                if (!response.IsSuccessStatusCode)
                {
                    statusMessage = response.StatusCode == System.Net.HttpStatusCode.Unauthorized
                        ? "Senha incorreta para este e-mail."
                        : "Não foi possivel iniciar a sessao agora.";
                    return;
                }

                var login = await response.Content.ReadFromJsonAsync<LoginApiResponse<EnterpriseSummaryApiDto>>();
                if (login?.Principal is null || string.IsNullOrWhiteSpace(login.SessionToken))
                {
                    statusMessage = "Resposta inesperada da API.";
                    return;
                }

                SessionState.SetPrincipal(new SessionPrincipalDto(
                    login.Principal.Id,
                    "Enterprise",
                    login.Principal.Name,
                    login.Principal.Email,
                    login.Principal.Slug), login.SessionToken);

                Navigation.NavigateTo($"/e/{login.Principal.Slug}/dashboard");
                return;
            }

            var userRequest = new LoginRequest(email.Trim(), password);
            var userResponse = await client.PostAsJsonAsync("/api/users/login", userRequest);
            if (!userResponse.IsSuccessStatusCode)
            {
                statusMessage = userResponse.StatusCode == System.Net.HttpStatusCode.Unauthorized
                    ? "Senha incorreta para este e-mail."
                    : "Não foi possivel iniciar a sessao agora.";
                return;
            }

            var userLogin = await userResponse.Content.ReadFromJsonAsync<LoginApiResponse<UserSummaryApiDto>>();
            if (userLogin?.Principal is null || string.IsNullOrWhiteSpace(userLogin.SessionToken))
            {
                statusMessage = "Resposta inesperada da API.";
                return;
            }

            SessionState.SetPrincipal(new SessionPrincipalDto(
                userLogin.Principal.Id,
                "User",
                userLogin.Principal.FullName,
                userLogin.Principal.Email), userLogin.SessionToken);

            Navigation.NavigateTo("/my-dashboard");
            return;
        }
        catch
        {
            statusMessage = "Erro ao conectar com a API.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
